@page
@model Letsgo.Pages.PreferitiModel
@{
    ViewData["Title"] = "I tuoi preferiti";
}

<style>
    .favorites-hero {
        background: linear-gradient(135deg, #198754, #75d69c);
        color: white;
        border-radius: 26px;
        padding: 36px;
        box-shadow: 0 12px 35px rgba(25, 135, 84, 0.22);
    }

    .favorite-card {
        border: none;
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
        transition: 0.2s ease;
        overflow: hidden;
    }

    .favorite-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.13);
    }

    .favorite-title {
        font-weight: 800;
        color: #212529;
    }

    .airport-text {
        color: #6c757d;
        font-size: 0.95rem;
    }

    .info-box {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 13px 15px;
        height: 100%;
    }

    .info-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 700;
        color: #6c757d;
        margin-bottom: 3px;
    }

    .info-value {
        font-weight: 700;
        color: #212529;
    }

    .empty-box {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .saved-date {
        border-top: 1px solid #eef0f2;
        margin-top: 20px;
        padding-top: 14px;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .alert {
        border-radius: 16px;
    }
</style>

<div class="container mt-4 mb-5">

    <div class="favorites-hero mb-4">
        <h1 class="mb-2">I miei preferiti</h1>
        <p class="mb-0">
            Qui trovi tutte le destinazioni che hai salvato durante le tue ricerche.
        </p>
    </div>

    @if (TempData["MessaggioSuccesso"] != null)
    {
        <div class="alert alert-success shadow-sm mt-3">
            @TempData["MessaggioSuccesso"]
        </div>
    }

    @if (Model.Destinazioni.Count == 0)
    {
        <div class="empty-box mt-4">
            <h4 class="fw-bold mb-2">Nessuna destinazione salvata</h4>
            <p class="text-muted mb-0">
                Non hai ancora salvato nessuna destinazione.
            </p>
        </div>
    }
    else
    {
        <div class="row mt-3 g-4">
            @foreach (var destinazione in Model.Destinazioni)
            {
                <div class="col-md-6">
                    <div class="card favorite-card h-100">
                        <div class="card-body p-4">

                            <h5 class="favorite-title mb-1">
                                @destinazione.CittaDestinazione
                            </h5>

                            <div class="airport-text mb-4">
                                Aeroporto: @destinazione.AeroportoDestinazione
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="info-box">
                                        <span class="info-label">Area</span>
                                        <span class="info-value">@destinazione.AreaGeografica</span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="info-box">
                                        <span class="info-label">Partenza</span>
                                        <span class="info-value">@destinazione.AeroportoPartenza</span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="info-box">
                                        <span class="info-label">Data partenza</span>
                                        <span class="info-value">@destinazione.DataPartenza.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>

                                @if (destinazione.DataRitorno.HasValue)
                                {
                                    <div class="col-md-6">
                                        <div class="info-box">
                                            <span class="info-label">Data ritorno</span>
                                            <span class="info-value">@destinazione.DataRitorno.Value.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </div>
                                }

                                @if (destinazione.Prezzo.HasValue)
                                {
                                    <div class="col-md-6">
                                        <div class="info-box">
                                            <span class="info-label">Prezzo</span>
                                            <span class="info-value">@destinazione.Prezzo €</span>
                                        </div>
                                    </div>
                                }

                                @if (destinazione.Temperatura.HasValue)
                                {
                                    <div class="col-md-6">
                                        <div class="info-box">
                                            <span class="info-label">Temperatura</span>
                                            <span class="info-value">@destinazione.Temperatura °C</span>
                                        </div>
                                    </div>
                                }
                                @if(destinazione.DurataInOre.HasValue)
                                {
                                    <div class="col-md-6">
                                        <div class="info-box">
                                            <span class="info-label">Durata</span>
                                            <span class="info-value">@destinazione.DurataInOre?.ToString("0.##") ore</span>
                                        </div>
                                    </div>
                                    
                                }

                                    

                                @if (!string.IsNullOrWhiteSpace(destinazione.DescrizioneMeteo))
                                {
                                    <div class="col-12">
                                        <div class="info-box">
                                            <span class="info-label">Meteo</span>
                                            <span class="info-value">@destinazione.DescrizioneMeteo</span>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="saved-date">
                                Salvata il @destinazione.DataSalvataggio.ToString("dd/MM/yyyy HH:mm")
                            </div>
                           
                            <div class="mt-3 text-end">
                                <form method="post" asp-page-handler="Elimina" asp-route-id="@destinazione.Id">
                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Sei sicuro di voler eliminare questa destinazione?');">
                                        <i class="bi bi-trash"></i> Elimina
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>