@page
@model Letsgo.Pages.PreferitiModel
@{
    ViewData["Title"] = "I tuoi preferiti";
}
<div class="container mt-4">
    <h1>I miei preferiti</h1>

    @if (Model.Destinazioni.Count == 0)
    {
        <p class="mt-3">Non hai ancora salvato nessuna destinazione.</p>
    }
    else
    {
        <div class="row mt-3">
            @foreach (var destinazione in Model.Destinazioni)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@destinazione.CittaDestinazione (@destinazione.AeroportoDestinazione)</h5>
                            <p class="card-text"><strong>Area:</strong> @destinazione.AreaGeografica</p>
                            <p class="card-text"><strong>Partenza:</strong> @destinazione.AeroportoPartenza</p>
                            <p class="card-text"><strong>Data di Partenza:</strong> @destinazione.DataPartenza.ToString("dd/MM/yyyy")</p>

                            @if (destinazione.DataRitorno.HasValue)
                            {
                                <p class="card-text"><strong>Data ritorno:</strong> @destinazione.DataRitorno.Value.ToString("dd/MM/yyyy")</p>
                            }

                            @if (destinazione.Prezzo.HasValue)
                            {
                                <p class="card-text"><strong>Prezzo:</strong> @destinazione.Prezzo €</p>
                            }

                            @if (destinazione.Temperatura.HasValue)
                            {
                                <p class="card-text"><strong>Temperatura:</strong> @destinazione.Temperatura °C</p>
                            }

                            @if (!string.IsNullOrWhiteSpace(destinazione.DescrizioneMeteo))
                            {
                                <p class="card-text"><strong>Meteo:</strong> @destinazione.DescrizioneMeteo</p>
                            }

                            <p class="card-text text-muted">
                                <small>Salvata il @destinazione.DataSalvataggio.ToString("dd/MM/yyyy HH:mm")</small>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
        @if (TempData["MessaggioSuccesso"] != null)
        {
            <div class="alert alert-success mt-3">
                @TempData["MessaggioSuccesso"]
            </div>
        }
    }
</div>