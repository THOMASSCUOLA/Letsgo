@page
@model Letsgo.Pages.SearchModel
@{
    ViewData["Title"] = "Ricerca Viaggio";
}

<style>
    body {
        background: #f4f7fb;
    }

    .hero {
        background: linear-gradient(135deg, #0d6efd, #6ea8fe);
        color: white;
        border-radius: 24px;
        padding: 36px;
        box-shadow: 0 12px 35px rgba(13, 110, 253, 0.25);
    }

    .box {
        border: none;
        border-radius: 22px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    }

    .form-control,
    .form-select {
        border-radius: 14px;
        padding: 11px 14px;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
    }

    .btn {
        border-radius: 14px;
        font-weight: 600;
        padding: 10px 22px;
    }

    .result-card {
        border: none;
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
        transition: 0.2s;
    }

        .result-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.13);
        }

    .info {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 14px;
        height: 100%;
    }

        .info small {
            color: #6c757d;
            font-weight: 600;
        }

        .info div {
            font-weight: 700;
            color: #212529;
            margin-top: 3px;
        }

    .ai-badge {
        background: #fff3cd;
        color: #664d03;
        border-radius: 14px;
        padding: 10px 14px;
        font-weight: 700;
    }

    .ai-card {
        border: 2px solid #ffc107;
        border-radius: 18px;
        background: #fffdf5;
    }

    .alert {
        border-radius: 16px;
    }
</style>

<div class="container mt-4 mb-5">

    <div class="hero mb-4">
        <h1 class="mb-2">Ricerca viaggio</h1>
        <p class="mb-0">
            Trova destinazioni consigliate in base ad area geografica, date, voli e meteo.
        </p>
    </div>

    <div class="card box mb-4">
        <div class="card-body p-4">
            <form method="post" class="row g-3">

                <div class="col-md-4">
                    <label asp-for="AeroportoPartenza" class="form-label">Aeroporto di partenza</label>
                    <input asp-for="AeroportoPartenza" class="form-control" placeholder="Es. MXP" />
                </div>

                <div class="col-md-4">
                    <label asp-for="AreaSelezionata" class="form-label">Area geografica</label>
                    <select asp-for="AreaSelezionata" class="form-select">
                        <option value="">-- Seleziona --</option>
                        <option>Europa</option>
                        <option>Asia</option>
                        <option>America</option>
                        <option>Africa</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="DataPartenza" class="form-label">Data partenza</label>
                    <input asp-for="DataPartenza" type="date" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label asp-for="DataRitorno" class="form-label">Data ritorno</label>
                    <input asp-for="DataRitorno" type="date" class="form-control" />
                </div>

                <div class="col-12 mt-3">
                    <button type="submit" class="btn btn-primary">
                        Cerca viaggio
                    </button>
                </div>

            </form>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.MessaggioErrore))
    {
        <div class="alert alert-danger shadow-sm mt-4">
            @Model.MessaggioErrore
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Messaggio))
    {
        <div class="alert alert-info shadow-sm mt-4">
            @Model.Messaggio
        </div>
    }

    @if (Model.RisultatiViaggio.Any())
    {
        <div class="mt-5">
            <h3 class="fw-bold mb-4">Destinazioni trovate</h3>

            <div class="row g-4">
                @foreach (var risultato in Model.RisultatiViaggio)
                {
                    <div class="col-12">
                        <div class="card result-card">
                            <div class="card-body p-4">

                                <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
                                    <div>
                                        <h4 class="fw-bold mb-1">
                                            @risultato.Citta
                                        </h4>
                                        <p class="text-muted mb-0">
                                            Aeroporto: @risultato.AeroportoDestinazione
                                        </p>
                                    </div>

                                    @if (Model.CittaConsigliataGemini == risultato.Citta)
                                    {
                                        <div class="ai-badge align-self-start">
                                            ⭐ Consigliata dall'AI
                                        </div>
                                    }
                                </div>

                                @if (Model.CittaConsigliataGemini == risultato.Citta)
                                {
                                    @if (!string.IsNullOrWhiteSpace(Model.ConsiglioGemini))
                                    {
                                        <div class="card ai-card mt-3 mb-4 shadow-sm">
                                            <div class="card-body">
                                                <h4 class="fw-bold mb-3">Consiglio AI</h4>
                                                <pre style="white-space: pre-wrap; font-family: inherit; margin-bottom: 0;">@Model.ConsiglioGemini</pre>
                                            </div>
                                        </div>
                                    }
                                }

                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <div class="info">
                                            <small>Prezzo</small>
                                            <div>
                                                @(risultato.Prezzo.HasValue ? risultato.Prezzo + " €" : "Non disponibile")
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="info">
                                            <small>Durata</small>
                                            <div>
                                                @(risultato.DurataTotaleMinuti.HasValue ? risultato.DurataTotaleMinuti + " minuti" : "Non disponibile")
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="info">
                                            <small>Compagnia</small>
                                            <div>
                                                @(string.IsNullOrWhiteSpace(risultato.Compagnia) ? "Non disponibile" : risultato.Compagnia)
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="info">
                                            <small>Scali</small>
                                            <div>
                                                @(risultato.NumeroScali == 0 ? "Nessuno" : risultato.NumeroScali)
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-8">
                                        <div class="info">
                                            <small>Meteo</small>
                                            <div>
                                                @(risultato.Temperatura.HasValue ? risultato.Temperatura + " °C" : "Temperatura non disponibile")
                                                -
                                                @(string.IsNullOrWhiteSpace(risultato.DescrizioneMeteo) ? "descrizione non disponibile" : risultato.DescrizioneMeteo)
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    <form method="post" asp-page-handler="Salva" class="mt-4">
                                        <input type="hidden" name="aeroportoPartenza" value="@Model.AeroportoPartenza" />
                                        <input type="hidden" name="areaSelezionata" value="@Model.AreaSelezionata" />
                                        <input type="hidden" name="dataPartenza" value="@Model.DataPartenza?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="dataRitorno" value="@Model.DataRitorno?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="cittaDestinazione" value="@risultato.Citta" />
                                        <input type="hidden" name="aeroportoDestinazione" value="@risultato.AeroportoDestinazione" />
                                        <input type="hidden" name="prezzoDaSalvare" value="@risultato.Prezzo" />
                                        <input type="hidden" name="temperaturaDaSalvare" value="@risultato.Temperatura" />
                                        <input type="hidden" name="descrizioneMeteoDaSalvare" value="@risultato.DescrizioneMeteo" />

                                        <button type="submit" class="btn btn-success">
                                            Salva questa destinazione
                                        </button>
                                    </form>
                                }

                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>