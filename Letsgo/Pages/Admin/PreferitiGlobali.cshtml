@page
@model Letsgo.Pages.Admin.PreferitiGlobaliModel
@{
    ViewData["Title"] = "Preferiti globali";
}

<style>
    .admin-hero {
        background: linear-gradient(135deg, #212529, #495057);
        color: white;
        border-radius: 26px;
        padding: 36px;
        box-shadow: 0 12px 35px rgba(33, 37, 41, 0.25);
    }

    .user-section {
        margin-top: 35px;
    }

    .user-header {
        background: white;
        border-radius: 20px;
        padding: 18px 22px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        border-left: 6px solid #0d6efd;
    }

    .user-email {
        font-weight: 800;
        color: #212529;
        margin-bottom: 4px;
    }

    .user-id {
        color: #6c757d;
        font-size: 0.85rem;
        word-break: break-all;
    }

    .admin-card {
        border: none;
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
        transition: 0.2s ease;
        overflow: hidden;
    }

    .admin-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.13);
    }

    .destination-title {
        font-weight: 800;
        color: #212529;
    }

    .airport-text {
        color: #6c757d;
        font-size: 0.95rem;
    }

    .info-box {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 13px 15px;
        height: 100%;
    }

    .info-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 700;
        color: #6c757d;
        margin-bottom: 3px;
    }

    .info-value {
        font-weight: 700;
        color: #212529;
    }

    .saved-date {
        border-top: 1px solid #eef0f2;
        margin-top: 20px;
        padding-top: 14px;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .empty-box {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
        text-align: center;
    }
</style>

<div class="container mt-4 mb-5">

    <div class="admin-hero mb-4">
        <h1 class="mb-2">Preferiti di tutti gli utenti</h1>
        <p class="mb-0">
            Visualizza le destinazioni salvate dagli utenti registrati.
        </p>
    </div>

    @if (Model.Destinazioni.Count == 0)
    {
        <div class="empty-box mt-4">
            <h4 class="fw-bold mb-2">Nessuna destinazione salvata</h4>
            <p class="text-muted mb-0">
                Non ci sono ancora destinazioni salvate.
            </p>
        </div>
    }
    else
    {
        @foreach (var gruppoUtente in Model.Destinazioni
            .GroupBy(d => new { d.IdUtente, d.EmailUtente })
            .OrderBy(g => g.Key.EmailUtente))
        {
            <div class="user-section">

                <div class="user-header mb-4">
                    <div class="user-email">
                        @gruppoUtente.Key.EmailUtente
                    </div>
                    <div class="user-id">
                        ID utente: @gruppoUtente.Key.IdUtente
                    </div>
                    <div class="text-muted mt-1">
                        Destinazioni salvate: @gruppoUtente.Count()
                    </div>
                </div>

                <div class="row g-4">
                    @foreach (var destinazione in gruppoUtente.OrderByDescending(d => d.DataSalvataggio))
                    {
                        <div class="col-md-6">
                            <div class="card admin-card h-100">
                                <div class="card-body p-4">

                                    <h5 class="destination-title mb-1">
                                        @destinazione.CittaDestinazione
                                    </h5>

                                    <div class="airport-text mb-4">
                                        Aeroporto: @destinazione.AeroportoDestinazione
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="info-box">
                                                <span class="info-label">Area</span>
                                                <span class="info-value">@destinazione.AreaGeografica</span>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="info-box">
                                                <span class="info-label">Partenza</span>
                                                <span class="info-value">@destinazione.AeroportoPartenza</span>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="info-box">
                                                <span class="info-label">Data partenza</span>
                                                <span class="info-value">@destinazione.DataPartenza.ToString("dd/MM/yyyy")</span>
                                            </div>
                                        </div>

                                        @if (destinazione.DataRitorno.HasValue)
                                        {
                                            <div class="col-md-6">
                                                <div class="info-box">
                                                    <span class="info-label">Data ritorno</span>
                                                    <span class="info-value">@destinazione.DataRitorno.Value.ToString("dd/MM/yyyy")</span>
                                                </div>
                                            </div>
                                        }

                                        @if (destinazione.Prezzo.HasValue)
                                        {
                                            <div class="col-md-6">
                                                <div class="info-box">
                                                    <span class="info-label">Prezzo</span>
                                                    <span class="info-value">@destinazione.Prezzo €</span>
                                                </div>
                                            </div>
                                        }

                                        @if (destinazione.Temperatura.HasValue)
                                        {
                                            <div class="col-md-6">
                                                <div class="info-box">
                                                    <span class="info-label">Temperatura</span>
                                                    <span class="info-value">@destinazione.Temperatura °C</span>
                                                </div>
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(destinazione.DescrizioneMeteo))
                                        {
                                            <div class="col-12">
                                                <div class="info-box">
                                                    <span class="info-label">Meteo</span>
                                                    <span class="info-value">@destinazione.DescrizioneMeteo</span>
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <div class="saved-date">
                                        Salvata il @destinazione.DataSalvataggio.ToString("dd/MM/yyyy HH:mm")
                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        }
    }
</div>
```
